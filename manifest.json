{
  "manifest_version": 3,
  "name": "API Testing Tool by Amie",
  "description": "A lightweight browser extension for testing HTTP APIs (GET, POST, PUT, PATCH, DELETE) directly from the browser.",
  "version": "1.0",

  "action": {
    "default_popup": "dist/index.html",
  "default_icon": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png"
  }
},

  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
  "16": "icons/icon16.png",
  "32": "icons/icon32.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
},

  "host_permissions": [
    "<all_urls>"
  ]
}